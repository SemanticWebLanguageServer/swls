@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:MinInclusive a sh:NodeShape;
  sh:targetClass :Node;
  sh:property [
    sh:path :p;
    sh:minCount 2;
  ].

